MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/bridgeid?retryWrites=true&w=majority"
NEXTAUTH_URL="http://localhost:3000" # Use https://bridge-id.vercel.app for production
NEXTAUTH_SECRET="replace_with_a_long_random_secret"

GOOGLE_CLIENT_ID="replace_with_google_client_id"
GOOGLE_CLIENT_SECRET="replace_with_google_client_secret"

GEMINI_API_KEY="replace_with_gemini_api_key"
UPLOADTHING_TOKEN="replace_with_uploadthing_token"

NEXT_PUBLIC_GEMINI_ENABLED=true
NEXT_PUBLIC_UPLOADTHING_ENABLED=true
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
